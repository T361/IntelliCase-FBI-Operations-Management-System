<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.intellicase.presentation.EvidenceVaultController"
            fitToWidth="true" styleClass="scroll-pane" stylesheets="@CyberpunkUI.css">
<VBox spacing="20" alignment="TOP_LEFT">
    <padding><Insets top="24" right="24" bottom="24" left="24" /></padding>

    <Label text="EVIDENCE VAULT" styleClass="page-title" />
    <Label text="Track evidence custody, calculate agent workloads, and review audit trails." styleClass="page-subtitle" />

    <!-- UC-01: Initiate Digital Handshake -->
    <VBox styleClass="form-card" spacing="12">
        <Label text="UC-01: Initiate Digital Handshake" styleClass="section-title" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox spacing="4"><Label text="Evidence ID" styleClass="field-label" /><TextField fx:id="handshakeEvidenceIdField" promptText="EVD-XXX" styleClass="neon-input" prefWidth="120" /></VBox>
            <VBox spacing="4"><Label text="Recipient ID" styleClass="field-label" /><TextField fx:id="handshakeRecipientIdField" promptText="AGT-XXX" styleClass="neon-input" prefWidth="120" /></VBox>
            <VBox spacing="4"><Label text="Digital Signature (AES)" styleClass="field-label" /><TextField fx:id="handshakeSignatureField" promptText="Your Signature" styleClass="neon-input" prefWidth="140" /></VBox>
            <Button fx:id="handshakeBtn" text="⚡ Initiate Handshake" styleClass="action-button" onAction="#handleDigitalHandshake" />
        </HBox>
        <Label fx:id="handshakeResultLabel" text="" styleClass="result-label" />
    </VBox>

    <!-- UC-05: Smart Load Score Assignment -->
    <VBox styleClass="form-card" spacing="12">
        <Label text="UC-05: Smart Load Score Assignment" styleClass="section-title" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox spacing="4"><Label text="Agent ID" styleClass="field-label" /><TextField fx:id="loadAgentIdField" promptText="AGT-XXX" styleClass="neon-input" prefWidth="180" /></VBox>
            <VBox spacing="4"><Label text="Select Active Cases" styleClass="field-label" /><MenuButton fx:id="loadCaseMenuButton" text="Cases to Assign" styleClass="neon-input" prefWidth="160" /></VBox>
            <Button fx:id="loadScoreBtn" text="📊 Assign Load Score" styleClass="action-button" onAction="#handleLoadScore" />
            <Label fx:id="loadScoreResultLabel" text="" styleClass="result-label" />
        </HBox>
    </VBox>

    <!-- UC-03: View Immutable Audit Trail -->
    <VBox styleClass="form-card" spacing="12">
        <Label text="UC-03: View Immutable Audit Trail" styleClass="section-title" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox spacing="4"><Label text="Target ID" styleClass="field-label" /><TextField fx:id="auditTargetIdField" promptText="Target entity ID" styleClass="neon-input" prefWidth="220" /></VBox>
            <Button fx:id="auditTrailBtn" text="🔍 View Audit Trail" styleClass="action-button" onAction="#handleViewAuditTrail" />
            <Label fx:id="auditResultLabel" text="" styleClass="result-label" />
        </HBox>
        <TableView fx:id="auditTable" prefHeight="200" styleClass="neon-table">
            <columns>
                <TableColumn fx:id="auditLogIdColumn" text="Log ID" prefWidth="80" />
                <TableColumn fx:id="auditActionColumn" text="Action" prefWidth="200" />
                <TableColumn fx:id="auditActorColumn" text="Actor" prefWidth="140" />
                <TableColumn fx:id="auditTimestampColumn" text="Timestamp" prefWidth="200" />
            </columns>
        </TableView>
        <Label fx:id="watermarkLabel" text="" styleClass="result-label" style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-style: italic;" visible="false" />
    </VBox>
</VBox>
</ScrollPane>
