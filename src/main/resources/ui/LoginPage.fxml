<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.intellicase.presentation.LoginController"
           style="-fx-background-color: transparent;">

    <VBox alignment="CENTER" spacing="0">
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="10" right="24" bottom="10" left="24" /></padding>
            <Button text="← BACK" styleClass="neon-button" onAction="#goBack"
                    style="-fx-font-size: 11px; -fx-padding: 5 14;" />
            <Label text="AGENT AUTHENTICATION PORTAL" styleClass="neon-chip" />
        </HBox>

        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
            <VBox styleClass="form-card" spacing="18" maxWidth="440"
                  style="-fx-padding: 40 48;">
                <Separator styleClass="neon-separator" />

                <VBox spacing="6">
                    <Label text="USERNAME" styleClass="field-label" />
                    <TextField fx:id="usernameField" styleClass="neon-input"
                               promptText="agent_username" />
                </VBox>

                <VBox spacing="6">
                    <Label text="PASSWORD" styleClass="field-label" />
                    <HBox spacing="8" alignment="CENTER">
                        <StackPane HBox.hgrow="ALWAYS">
                            <PasswordField fx:id="passwordField" styleClass="neon-input"
                                           promptText="••••••••" />
                            <TextField fx:id="passwordVisible" styleClass="neon-input"
                                       promptText="••••••••" visible="false"
                                       managed="false" />
                        </StackPane>
                        <Button fx:id="togglePwdBtn" text="👁" styleClass="neon-button"
                                onAction="#togglePassword"
                                style="-fx-font-size: 14px; -fx-padding: 6 12;" />
                    </HBox>
                </VBox>

                <VBox spacing="6">
                    <Label text="SELECT CLEARANCE ROLE" styleClass="field-label" />
                    <ComboBox fx:id="roleComboBox" styleClass="neon-input"
                              maxWidth="Infinity" promptText="-- Select your role --" />
                </VBox>

                <Label fx:id="errorLabel" text="" wrapText="true"
                       style="-fx-text-fill: #ff4444; -fx-font-size: 12px;" />

                <Button text="AUTHENTICATE →" styleClass="action-button"
                        maxWidth="Infinity" onAction="#handleLogin"
                        style="-fx-font-size: 14px; -fx-padding: 12 0;" />

                <!-- Biometric divider -->
                <HBox alignment="CENTER" spacing="10" style="-fx-padding: 4 0 0 0;">
                    <Separator styleClass="neon-separator" HBox.hgrow="ALWAYS" />
                    <Label text="OR USE BIOMETRICS" styleClass="field-label"
                           style="-fx-font-size: 10px;" />
                    <Separator styleClass="neon-separator" HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Biometric login buttons -->
                <HBox spacing="10" alignment="CENTER">
                    <Button text="🪪  FACE ID" styleClass="action-button"
                            onAction="#handleFaceLogin"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            style="-fx-font-size: 13px; -fx-padding: 10 0;" />
                    <Button text="📷  QR SCAN" styleClass="neon-button"
                            onAction="#handleQrLogin"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            style="-fx-font-size: 13px; -fx-padding: 10 0;" />
                </HBox>

                <HBox alignment="CENTER" spacing="6">
                    <Label text="Need access?" styleClass="neon-label" />
                    <Button text="Request Sign Up" styleClass="neon-button"
                            onAction="#goSignup"
                            style="-fx-font-size: 11px; -fx-padding: 4 12;" />
                </HBox>
                <Separator styleClass="neon-separator" />
                <Label text="Demo: director/Director@2026  |  agent1/Agent@2026  |  public1/Public@2026"
                       style="-fx-font-size: 10px; -fx-text-fill: rgba(201,169,77,0.5);
                              -fx-font-style: italic;" wrapText="true" />
            </VBox>
        </VBox>
    </VBox>
</StackPane>
