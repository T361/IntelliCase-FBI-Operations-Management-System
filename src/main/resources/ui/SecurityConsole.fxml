<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.intellicase.presentation.SecurityConsoleController"
            fitToWidth="true" styleClass="scroll-pane" stylesheets="@CyberpunkUI.css">

<VBox spacing="24" alignment="TOP_LEFT">
    <padding><Insets top="28" right="28" bottom="28" left="28" /></padding>

    <!-- Page Header -->
    <VBox spacing="4">
        <Label text="🔒  UC-08  ·  SYSTEM-WIDE AUDIT LOCKDOWN" styleClass="page-title" />
        <Label text="Director-level freeze — suspends all write/edit/delete operations globally across all nodes."
               styleClass="page-subtitle" />
    </VBox>

    <!-- Live Status Banner -->
    <VBox fx:id="lockdownBanner" styleClass="lockdown-banner-normal" spacing="10">
        <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>
        <HBox spacing="16" alignment="CENTER_LEFT">
            <Circle fx:id="statusDot" radius="8" styleClass="status-dot" />
            <VBox spacing="2">
                <Label fx:id="lockdownStatusTitle"
                       text="SYSTEM STATUS: NORMAL OPERATIONAL PARAMETERS"
                       styleClass="lockdown-status-title-normal" />
                <Label fx:id="lockdownStatusSub"
                       text="All write operations are enabled. No active audit freeze."
                       styleClass="audit-subtitle" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <VBox spacing="2" alignment="CENTER_RIGHT">
                <Label fx:id="lockdownTimestampLabel" text="" styleClass="audit-footer-label" />
                <Label fx:id="lockdownActorLabel" text="" styleClass="audit-footer-label" />
            </VBox>
        </HBox>
    </VBox>

    <HBox spacing="24">

        <!-- LEFT: UC-08 3-Step Lockdown -->
        <VBox fx:id="lockdownPanel" spacing="0" HBox.hgrow="ALWAYS" styleClass="audit-panel">

            <!-- Panel header -->
            <HBox styleClass="audit-header" alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="16" right="20" bottom="16" left="20" /></padding>
                <Label text="🔴" styleClass="card-icon" />
                <VBox spacing="2">
                    <Label text="INITIATE LOCKDOWN SEQUENCE" styleClass="audit-title" />
                    <Label text="Follow all 3 steps in order. Credentials are required for each stage."
                           styleClass="audit-subtitle" />
                </VBox>
            </HBox>

            <VBox spacing="20" style="-fx-padding: 20 20 20 20;">

                <!-- Step 1: UPS Check -->
                <VBox spacing="10" styleClass="lockdown-step">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="STEP 1" styleClass="step-badge" />
                        <Label text="UPS DEPENDENCY CHECK  (Special Requirement 2)"
                               styleClass="field-label" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="upsStatusLabel" text="PENDING..." styleClass="audit-footer-label" />
                    </HBox>
                    <Button fx:id="upsCheckBtn" text="⚡  RUN UPS CHECK"
                            styleClass="action-button" onAction="#handleUpsCheck"
                            maxWidth="Infinity" />
                </VBox>

                <Separator styleClass="neon-separator" />

                <!-- Step 2: Director Credentials -->
                <VBox spacing="12" styleClass="lockdown-step">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="STEP 2" styleClass="step-badge" />
                        <Label text="DIRECTOR BIOMETRIC + SECONDARY PASSWORD (E1 / E3)"
                               styleClass="field-label" />
                    </HBox>
                    <GridPane hgap="16" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50" />
                            <ColumnConstraints percentWidth="50" />
                        </columnConstraints>
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="DIRECTOR ID (Biometric Reference)" styleClass="field-label" />
                            <TextField fx:id="directorIdField" promptText="DIR-0001"
                                       styleClass="text-field" />
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="SECONDARY PASSWORD" styleClass="field-label" />
                            <PasswordField fx:id="directorPasswordField"
                                          promptText="Enter Director password"
                                          styleClass="text-field" />
                        </VBox>
                    </GridPane>
                    <Label text="ℹ  Credentials:  ID = DIR-0001  |  Password = BLACKSITE-ALPHA  |  Type EXPIRED to test E3"
                           styleClass="lockdown-hint" />
                </VBox>

                <Separator styleClass="neon-separator" />

                <!-- Step 3: Execute -->
                <VBox spacing="10" styleClass="lockdown-step">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="STEP 3" styleClass="step-badge" />
                        <Label text="EXECUTE GLOBAL LOCKDOWN SEQUENCE" styleClass="field-label" />
                    </HBox>
                    <Button fx:id="lockdownBtn" text="🔴  INITIATE SYSTEM-WIDE AUDIT LOCKDOWN"
                            styleClass="danger-button" onAction="#handleActivateLockdown"
                            maxWidth="Infinity" />
                    <Label fx:id="lockdownResultLabel" text="" styleClass="audit-result-label" />
                </VBox>

                <!-- DOJ Notification (hidden until lockdown activated) -->
                <VBox fx:id="dojPanel" spacing="8" styleClass="doj-panel"
                      managed="false" visible="false">
                    <padding><Insets top="14" right="18" bottom="14" left="18" /></padding>
                    <Label text="📋  DOJ NOTIFICATION DISPATCHED  (Special Requirement 3)"
                           styleClass="section-title" />
                    <Label fx:id="dojTimestampLabel" text="" styleClass="neon-label" />
                    <Label text="All active nodes synchronized. System is now READ-ONLY."
                           styleClass="audit-subtitle" />
                    <Label text="➜  Use 'Lockdown Control' in the sidebar to deactivate."
                           styleClass="lockdown-hint" />
                </VBox>
            </VBox>
        </VBox>

        <!-- RIGHT: UC-07 + UC-09 -->
        <VBox spacing="20" prefWidth="310">

            <!-- UC-07 -->
            <VBox styleClass="form-card" spacing="14">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="🕶" styleClass="card-icon" />
                    <VBox spacing="2">
                        <Label text="UC-07  ·  SHADOW PROFILE" styleClass="section-title" />
                        <Label text="Create encrypted confidential informant record."
                               styleClass="card-uc" />
                    </VBox>
                </HBox>
                <Separator styleClass="neon-separator" />
                <VBox spacing="6">
                    <Label text="PROFILE ID" styleClass="field-label" />
                    <TextField fx:id="profileIdField" promptText="SP-XXX" styleClass="text-field" />
                </VBox>
                <VBox spacing="6">
                    <Label text="ALIAS / CODENAME" styleClass="field-label" />
                    <TextField fx:id="aliasField" promptText="Codename" styleClass="text-field" />
                </VBox>
                <VBox spacing="6">
                    <Label text="TRUE IDENTITY / RAW INTEL" styleClass="field-label" />
                    <TextField fx:id="rawDataField" promptText="Actual name and intelligence"
                               styleClass="text-field" />
                </VBox>
                <VBox spacing="6">
                    <Label text="LINKED CASE ID" styleClass="field-label" />
                    <TextField fx:id="shadowCaseIdField" promptText="CASE-XXX"
                               styleClass="text-field" />
                </VBox>
                <Button fx:id="createShadowBtn" text="▶  CREATE ENCRYPTED PROFILE"
                        styleClass="action-button" onAction="#handleCreateShadowProfile"
                        maxWidth="Infinity" />
                <Label fx:id="shadowResultLabel" text="" styleClass="audit-result-label" />
                
                <Separator styleClass="neon-separator" />
                <VBox spacing="6">
                    <Label text="VIEW SHADOW PROFILE (E1)" styleClass="field-label" />
                    <HBox spacing="8">
                        <TextField fx:id="viewProfileIdField" promptText="SP-XXX" styleClass="text-field" prefWidth="100"/>
                        <TextField fx:id="viewAgentIdField" promptText="Your Agent ID" styleClass="text-field" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Button fx:id="viewShadowBtn" text="👁  DECRYPT DETAILS (MFA)" styleClass="action-button" onAction="#handleViewShadowProfile" maxWidth="Infinity" />
                </VBox>
                
                <Separator styleClass="neon-separator" />
                <VBox spacing="6">
                    <Label text="LINK FINANCIAL PAYOUT (E3)" styleClass="field-label" />
                    <CheckBox fx:id="identityVerifiedCheck" text="Informant Identity Verified" styleClass="neon-label" />
                    <Button fx:id="linkFinancialBtn" text="💲  LINK SECURE PAYOUT" styleClass="action-button" onAction="#handleLinkFinancials" maxWidth="Infinity" />
                </VBox>
            </VBox>

            <!-- UC-09 -->
            <VBox styleClass="form-card" spacing="14">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="▲" styleClass="card-icon" />
                    <VBox spacing="2">
                        <Label text="UC-09  ·  PROMOTE CLEARANCE" styleClass="section-title" />
                        <Label text="Elevate agent security classification by one level."
                               styleClass="card-uc" />
                    </VBox>
                </HBox>
                <Separator styleClass="neon-separator" />
                <VBox spacing="6">
                    <Label text="AGENT ID" styleClass="field-label" />
                    <TextField fx:id="promoteAgentIdField" promptText="AGT-XXXX-XXXX"
                               styleClass="text-field" />
                </VBox>
                <Button fx:id="promoteBtn" text="▲  PROMOTE CLEARANCE"
                        styleClass="action-button" onAction="#handlePromoteClearance"
                        maxWidth="Infinity" />
                <Label fx:id="promoteResultLabel" text="" styleClass="audit-result-label" />
            </VBox>
        </VBox>
    </HBox>
</VBox>
</ScrollPane>
