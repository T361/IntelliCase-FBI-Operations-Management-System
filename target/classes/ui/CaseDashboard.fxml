<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.intellicase.presentation.CaseDashboardController"
            fitToWidth="true" styleClass="scroll-pane" stylesheets="@CyberpunkUI.css">
<VBox spacing="20" alignment="TOP_LEFT">
    <padding><Insets top="24" right="24" bottom="24" left="24" /></padding>

    <Label text="CASE MANAGEMENT DASHBOARD" styleClass="page-title" />
    <Label text="Initialize new investigations and audit evidence integrity." styleClass="page-subtitle" />

    <!-- UC-11: Create Smart Case -->
    <VBox styleClass="form-card" spacing="12">
        <Label text="UC-11: Create Smart Case Initializer" styleClass="section-title" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox spacing="4"><Label text="Status" styleClass="field-label" /><TextField fx:id="caseStatusField" promptText="OPEN" styleClass="neon-input" prefWidth="120" /></VBox>
            <VBox spacing="4"><Label text="Priority" styleClass="field-label" /><TextField fx:id="casePriorityField" promptText="HIGH" styleClass="neon-input" prefWidth="100" /></VBox>
            <VBox spacing="4"><Label text="Location" styleClass="field-label" /><TextField fx:id="caseLocationField" promptText="Field Office" styleClass="neon-input" prefWidth="160" /></VBox>
        </HBox>
        <VBox spacing="4">
            <Label text="Description" styleClass="field-label" />
            <TextArea fx:id="caseDescriptionArea" promptText="Enter case description..." styleClass="neon-input" prefHeight="80" />
        </VBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button fx:id="createCaseBtn" text="➕ Create Smart Case" styleClass="action-button" onAction="#handleCreateSmartCase" />
            <Label fx:id="caseResultLabel" text="" styleClass="result-label" />
        </HBox>
    </VBox>

    <!-- UC-14: Secure Evidence Inventory Audit -->
    <VBox styleClass="form-card" spacing="12">
        <Label text="UC-14: Secure Evidence Inventory Audit" styleClass="section-title" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox spacing="4"><Label text="Agent ID" styleClass="field-label" /><TextField fx:id="inventoryAgentIdField" promptText="AGT-XXX" styleClass="neon-input" prefWidth="200" /></VBox>
            <Button fx:id="inventoryBtn" text="🔒 Run Inventory Audit" styleClass="action-button" onAction="#handleEvidenceInventory" />
        </HBox>
        <TableView fx:id="inventoryTable" prefHeight="220" styleClass="neon-table">
            <columns>
                <TableColumn fx:id="invEvidenceIdColumn" text="Evidence ID" prefWidth="120" />
                <TableColumn fx:id="invCaseIdColumn" text="Case ID" prefWidth="120" />
                <TableColumn fx:id="invStatusColumn" text="Status" prefWidth="100" />
                <TableColumn fx:id="invCustodianColumn" text="Custodian" prefWidth="120" />
                <TableColumn fx:id="invHashColumn" text="Integrity Hash" prefWidth="200" />
            </columns>
        </TableView>
    </VBox>
</VBox>
</ScrollPane>
