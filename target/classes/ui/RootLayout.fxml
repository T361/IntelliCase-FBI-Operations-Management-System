<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.intellicase.presentation.RootLayoutController"
           stylesheets="@CyberpunkUI.css" fx:id="rootStack">

    <BorderPane fx:id="mainBorder">
        <left>
            <VBox spacing="14" styleClass="sidebar" prefWidth="220">
                <padding><Insets top="20" right="16" bottom="20" left="16" /></padding>

                <Label text="INTELLICASE" styleClass="neon-title" />
                <Label text="FBI OPS TERMINAL" styleClass="sidebar-subtitle" />
                <Separator styleClass="neon-separator" />

                <Button fx:id="navMainMenu" text="⌂  Main Menu" styleClass="nav-button" onAction="#goMainMenu" maxWidth="Infinity" />
                <Button fx:id="navSecurity" text="🛡  Security Ops" styleClass="nav-button" onAction="#goSecurity" maxWidth="Infinity" />
                <Button fx:id="navEvidence" text="🔬  Evidence Vault" styleClass="nav-button" onAction="#goEvidence" maxWidth="Infinity" />
                <Button fx:id="navCases" text="📁  Case Dashboard" styleClass="nav-button" onAction="#goCases" maxWidth="Infinity" />

                <Region VBox.vgrow="ALWAYS" />

                <Separator styleClass="neon-separator" />
                <Label text="SYSTEM v2.0.1" styleClass="version-label" />
            </VBox>
        </left>

        <top>
            <HBox spacing="14" styleClass="topbar" alignment="CENTER_LEFT">
                <padding><Insets top="10" right="20" bottom="10" left="20" /></padding>
                <Circle radius="5" styleClass="status-dot" />
                <Label text="Active Agent: OMEGA-7" styleClass="neon-chip" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="timeLabel" text="00:00" styleClass="neon-chip" />
                <Label fx:id="threatLabel" text="Threat: Low" styleClass="threat-chip" />
                <Label fx:id="lockdownStatusLabel" text="Lockdown: INACTIVE" styleClass="lockdown-chip" />
            </HBox>
        </top>

        <center>
            <StackPane fx:id="contentPane" styleClass="content-area">
                <padding><Insets top="16" right="16" bottom="16" left="16" /></padding>
            </StackPane>
        </center>
    </BorderPane>
</StackPane>
