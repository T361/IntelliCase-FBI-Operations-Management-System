<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.intellicase.presentation.SecurityConsoleController"
            fitToWidth="true" styleClass="scroll-pane" stylesheets="@CyberpunkUI.css">
<VBox spacing="20" alignment="TOP_LEFT">
    <padding><Insets top="24" right="24" bottom="24" left="24" /></padding>

    <Label text="SECURITY OPERATIONS CONSOLE" styleClass="page-title" />
    <Label text="Manage shadow profiles, audit lockdown states, and clearance levels." styleClass="page-subtitle" />

    <!-- UC-07: Create Shadow Profile -->
    <VBox styleClass="form-card" spacing="12">
        <Label text="UC-07: Create Shadow Profile" styleClass="section-title" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox spacing="4"><Label text="Profile ID" styleClass="field-label" /><TextField fx:id="profileIdField" promptText="SP-XXX" styleClass="neon-input" prefWidth="160" /></VBox>
            <VBox spacing="4"><Label text="Alias" styleClass="field-label" /><TextField fx:id="aliasField" promptText="Codename" styleClass="neon-input" prefWidth="160" /></VBox>
            <VBox spacing="4"><Label text="Raw Data" styleClass="field-label" /><TextField fx:id="rawDataField" promptText="Plaintext intel" styleClass="neon-input" prefWidth="200" /></VBox>
            <VBox spacing="4"><Label text="Case ID" styleClass="field-label" /><TextField fx:id="shadowCaseIdField" promptText="CASE-XXX" styleClass="neon-input" prefWidth="140" /></VBox>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button fx:id="createShadowBtn" text="▶ Create Shadow Profile" styleClass="action-button" onAction="#handleCreateShadowProfile" />
            <Label fx:id="shadowResultLabel" text="" styleClass="result-label" />
        </HBox>
    </VBox>

    <!-- UC-08: Activate Audit Lockdown -->
    <VBox styleClass="form-card" spacing="12">
        <Label text="UC-08: Activate Audit Lockdown" styleClass="section-title" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button fx:id="lockdownBtn" text="⚠ ACTIVATE LOCKDOWN" styleClass="danger-button" onAction="#handleActivateLockdown" />
            <Label fx:id="lockdownResultLabel" text="" styleClass="result-label" />
        </HBox>
    </VBox>

    <!-- UC-09: Promote Security Clearance -->
    <VBox styleClass="form-card" spacing="12">
        <Label text="UC-09: Promote Security Clearance" styleClass="section-title" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox spacing="4"><Label text="Agent ID" styleClass="field-label" /><TextField fx:id="promoteAgentIdField" promptText="AGT-XXX" styleClass="neon-input" prefWidth="180" /></VBox>
            <Button fx:id="promoteBtn" text="▲ Promote Clearance" styleClass="action-button" onAction="#handlePromoteClearance" />
            <Label fx:id="promoteResultLabel" text="" styleClass="result-label" />
        </HBox>
    </VBox>

    <!-- UC-15: Deactivate Audit Lockdown -->
    <VBox styleClass="form-card" spacing="12">
        <Label text="UC-15: Deactivate System Audit Lockdown" styleClass="section-title" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox spacing="4"><Label text="Override Code" styleClass="field-label" /><TextField fx:id="overrideCodeField" promptText="OVERRIDE-ALPHA" styleClass="neon-input" prefWidth="220" /></VBox>
            <Button fx:id="deactivateBtn" text="✓ Deactivate Lockdown" styleClass="action-button" onAction="#handleDeactivateLockdown" />
            <Label fx:id="deactivateResultLabel" text="" styleClass="result-label" />
        </HBox>
    </VBox>
</VBox>
</ScrollPane>
